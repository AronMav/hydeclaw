# PostgreSQL — default password matches hydeclaw.toml [database].url
# Change both here and in config/hydeclaw.toml if you need a custom password.
POSTGRES_USER=hydeclaw
POSTGRES_PASSWORD=hydeclaw

# ─────────────────────────────────────────────────────────────
# Phase 62 RES-06: Docker resource limits (per-service caps)
# ─────────────────────────────────────────────────────────────
# Memory is in docker units: k, m, g (e.g. 256m, 2g).
# CPU is fractional cores (e.g. 0.5 = half a core, 1.5 = 1.5 cores).
POSTGRES_MEM_LIMIT=2g
POSTGRES_CPUS=1.5
SEARXNG_MEM_LIMIT=256m
SEARXNG_CPUS=0.5
BROWSER_RENDERER_MEM_LIMIT=1g
BROWSER_RENDERER_CPUS=1.0
MCP_DEFAULT_MEM_LIMIT=384m
MCP_DEFAULT_CPUS=0.5
